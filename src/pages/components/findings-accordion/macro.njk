{% from "components/severity/macro.njk" import severityTag %}

{% macro findingCard(finding) %}
  {% set _borderColour = {
    critical: '#d4351c',
    high:     '#f47738',
    medium:   '#f2a73d',
    low:      '#1d70b8',
    info:     '#b1b4b6'
  }[finding.severity] or '#b1b4b6' %}

<div class="app-finding-card" style="border-left-color: {{ _borderColour }}">
  <div class="app-finding-card__header">
    {{ severityTag(finding.severity) }}
    <span class="app-finding-card__section">{{ finding.section }}</span>
  </div>
  <dl class="app-finding-card__body">
    <div class="app-finding-card__row">
      <dt>Issue</dt>
      <dd>{{ finding.issue | renderLinks | safe }}</dd>
    </div>
    <div class="app-finding-card__row">
      <dt>Why it matters</dt>
      <dd>{{ finding.why_it_matters | renderLinks | safe }}</dd>
    </div>
    <div class="app-finding-card__row">
      <dt>Recommendation</dt>
      <dd>{{ finding.recommendation | renderLinks | safe }}</dd>
    </div>
  </dl>
</div>
{% endmacro %}
