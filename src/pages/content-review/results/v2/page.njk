{% extends "common/layout.njk" %}

{% from "govuk/components/notification-banner/macro.njk" import govukNotificationBanner %}
{% from "govuk/components/task-list/macro.njk" import govukTaskList %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}

{% set page = 'content-review' %}

{% block content %}
  <div class="govuk-width-container">
    <main class="govuk-main-wrapper" id="main-content" role="main">

      {# ── Notification banner — overall outcome ───────────────────────── #}
      {% if not hasFindings %}
        {{ govukNotificationBanner({
          type: "success",
          titleText: "No issues found",
          html: "<p class=\"govuk-body\">This document conforms to the GDS content standards and the DEFRA style guide.</p>"
        }) }}
      {% else %}
        {{ govukNotificationBanner({
          titleText: "Review complete",
          html: "<p class=\"govuk-body\">" + totalFindings + (" issue" if totalFindings == 1 else " issues") + " identified across the standards reviewed.</p>"
        }) }}
      {% endif %}

      {# ── Page heading ────────────────────────────────────────────────── #}
      <span class="govuk-caption-m" style="color: #505a5f">Guidance content review</span>
      <h1 class="govuk-heading-l">{{ documentTitle }}</h1>

      <p class="govuk-body-s">
        <a class="govuk-link" href="{{ originalResultsHref }}">View the original layout</a>
      </p>

      {# ── Structural drift warnings ───────────────────────────────────── #}
      {% if invariantWarnings | length %}
        <div class="govuk-warning-text">
          <span class="govuk-warning-text__icon" aria-hidden="true">!</span>
          <strong class="govuk-warning-text__text">
            <span class="govuk-visually-hidden">Warning</span>
            {% for warning in invariantWarnings %}{{ warning }}{% if not loop.last %}; {% endif %}{% endfor %}
          </strong>
        </div>
      {% endif %}

      {# ── Issue overview summary card ─────────────────────────────────── #}
      {% if severityRows | length %}
        <div class="govuk-grid-row">
          <div class="govuk-grid-column-one-third">
            {{ govukSummaryList({ card: { title: { text: "Issue overview" } }, rows: severityRows }) }}
          </div>
        </div>
      {% endif %}

      {# ── Findings — grouped task lists, each links to a detail page ───── #}
      <h2 class="govuk-heading-m">Findings ({{ totalFindings }})</h2>

      {% if importantItems | length %}
        <h3 class="govuk-heading-s">Important to fix</h3>
        {{ govukTaskList({ idPrefix: "important", items: importantItems }) }}
      {% endif %}

      {% if suggestionItems | length %}
        <h3 class="govuk-heading-s govuk-!-margin-top-6">Suggestions</h3>
        {{ govukTaskList({ idPrefix: "suggestions", items: suggestionItems }) }}
      {% endif %}

      {% if not totalFindings %}
        <p class="govuk-body">No findings were identified.</p>
      {% endif %}

      {# ── What was checked (secondary, collapsed) ─────────────────────── #}
      {% if conformanceSummaries | length %}
        <details class="govuk-details govuk-!-margin-top-6">
          <summary class="govuk-details__summary">
            <span class="govuk-details__summary-text">What was checked</span>
          </summary>
          <div class="govuk-details__text">
            {% for report in conformanceSummaries %}
              <h3 class="govuk-heading-s">{{ report.label }}</h3>
              <p class="govuk-body">{{ report.summary }}</p>
            {% endfor %}
          </div>
        </details>
      {% endif %}

      {# ── Token usage ─────────────────────────────────────────────────── #}
      {% if usage %}
        <p class="govuk-body-s" style="color: #505a5f; margin-top: 40px">
          Token usage — input: {{ usage.input_tokens }} · output: {{ usage.output_tokens }}
        </p>
      {% endif %}

      <p class="govuk-body govuk-!-margin-top-6">
        <a class="govuk-link" href="/content-review">Start another content review</a>
      </p>

    </main>
  </div>
{% endblock %}
