{% extends "common/layout.njk" %}

{% set pageTitle = 'Home' %}
{% set page = 'home' %}

{% block content %}
  <div class="defra-hero">
    <div class="govuk-width-container">
      <h1 class="govuk-heading-xl">RPA Guidance AI Usecase PoC</h1>
      <p class="govuk-body-l">
        A collection of AI-powered tools for managing and using RPA internal
        guidance documents.
      </p>
    </div>
  </div>

  <div class="govuk-width-container govuk-!-margin-top-6">

    <div class="dfe-tools-section dfe-tools-section--management">
      <h2 class="govuk-heading-l">
        Guidance Management
        <span class="dfe-tools-section__badge">Management</span>
      </h2>
      <p class="govuk-body">
        Tools for uploading, managing, and processing RPA guidance documents.
      </p>
      <div class="govuk-grid-row">
        <div class="govuk-grid-column-one-half">
          <div class="dfe-card">
            <div class="dfe-card-container">
              <h3 class="govuk-heading-m">
                <a
                  class="govuk-link dfe-card-link--header"
                  href="/guidance-documents"
                >
                  Guidance documents
                </a>
              </h3>
              <p class="govuk-body">
                Upload and manage RPA guidance documents for use by AI tools.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="dfe-tools-section dfe-tools-section--agents">
      <h2 class="govuk-heading-l">
        AI Agent Tools
        <span class="dfe-tools-section__badge">AI Agent</span>
      </h2>
      <p class="govuk-body">
        AI-powered agents with specific capabilities for process guidance.
      </p>
      <div class="govuk-grid-row">

        <div class="govuk-grid-column-one-half">
          <div class="dfe-card">
            <div class="dfe-card-container">
              <h3 class="govuk-heading-m">
                <a
                  class="govuk-link dfe-card-link--header"
                  href="/publishing-checks"
                >
                  Guidance pre-publishing checks
                </a>
                <strong class="govuk-tag govuk-tag--turquoise govuk-!-display-block govuk-!-margin-top-1 govuk-!-text-align-centre">
                  Prototype
                </strong>
              </h3>
              <p class="govuk-body">
                AI-assisted quality checks on guidance documents before
                publishing.
              </p>
            </div>
          </div>
        </div>

        <div class="govuk-grid-column-one-half">
          <div class="dfe-card">
            <div class="dfe-card-container">
              <h3 class="govuk-heading-m">
                <a
                  class="govuk-link dfe-card-link--header"
                  href="/content-review"
                >
                  Guidance content review
                </a>
                <strong class="govuk-tag govuk-tag--turquoise govuk-!-display-block govuk-!-margin-top-1 govuk-!-text-align-centre">
                  Prototype
                </strong>
              </h3>
              <p class="govuk-body">
                Review and analyse guidance content using AI to identify
                improvements.
              </p>
            </div>
          </div>
        </div>

      </div>
    </div>

  </div>
{% endblock %}
